# ---- Azure OpenAI (required for ingest + query) ----
# Rotate the old hardcoded key before using — it was committed to git history.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_EMBEDDING_DEPLOYMENT=embeddings
AZURE_CHAT_DEPLOYMENT=chat-gpt40

# ---- Admin panel password (shared token) ----
# Pick a strong random string. The frontend sends this as X-Admin-Token.
ADMIN_TOKEN=change-me-to-a-long-random-string

# ---- CORS ----
# Use "*" for quick local dev. In production set your Vercel URL, e.g.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*

# ---- Optional tuning ----
STORAGE_DIR=storage
MAX_TOKENS_PER_CHUNK=800
CHUNK_OVERLAP=100
TOP_K=5
SEED_DEMO=true
